# Тестовый портал Bitrix24 для seed-скрипта фикстур (scripts/seed-test-b24.mjs).
# Скопируй в .env.b24test и подставь РЕАЛЬНЫЙ вебхук тестового портала.
# .env.b24test — в .gitignore; НИКОГДА не коммить реальный токен.
#
# Полный URL входящего вебхука с завершающим слэшем (Разработчикам → Другое →
# Входящий вебхук; права crm). Формат:
#   B24_TEST_WEBHOOK=https://<портал>.bitrix24.ru/rest/<user_id>/<token>/
B24_TEST_WEBHOOK=https://your-portal.bitrix24.ru/rest/1/xxxxxxxxxxxxxxxx/
