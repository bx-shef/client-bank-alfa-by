# ─────────────────────────────────────────────────────────────────────────────
#  Alfa-Bank Belarus — SANDBOX config for the local OAuth/API demo
#  (scripts/alfa-oauth-test.mjs, run via `pnpm oauth:test`).
#
#  This is the TEST gateway (developerhub). Data is FAKE — nothing here touches
#  real money or real clients. Copy this file to `.env.alfabankby` (gitignored)
#  and fill in the secret. The script loads `.env.alfabankby` automatically.
#
#  ⚠ SANDBOX credentials ONLY. Never put production keys (ibapi2.alfabank.by) here.
#  ⚠ Sandbox quirks (expected, not bugs): the statement endpoint returns canned
#    data ignoring dateFrom/dateTo and the account number; some test accounts
#    answer HTTP 500. See docs/ALFA_API.md.
# ─────────────────────────────────────────────────────────────────────────────

# OAuth + API gateway — sandbox, non-standard port 8273. Keep as-is for sandbox.
ALFA_BASE_URL=https://developerhub.alfabank.by:8273

# client_id / redirect_uri are NOT secrets (they show up in the browser /authorize
# URL). Issued when the partner app is registered on developerhub. redirect_uri
# MUST exactly match the one registered for the app.
ALFA_CLIENT_ID=your-sandbox-client-id
ALFA_REDIRECT_URI=https://bank-import.bx-shef.by/oauth-alfabank-by/

# SECRET — local only, lives in .env.sandbox. Never commit / log / paste it.
ALFA_CLIENT_SECRET=

# Requested scope. `accounts` is enough for accounts + statement.
ALFA_SCOPE=accounts
