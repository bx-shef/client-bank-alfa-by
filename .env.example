# Alfa-Bank Belarus OAuth / API config (read by the backend/transport layer).
# Copy to `.env` and fill in. NEVER commit real secrets — `.env` is gitignored.
#
# OAuth base URL: sandbox `https://developerhub.alfabank.by:8273`,
# production `https://ibapi2.alfabank.by:8273`.
ALFA_BASE_URL=https://developerhub.alfabank.by:8273
# production:
# ALFA_BASE_URL=https://ibapi2.alfabank.by:8273

# client_id / redirect_uri are not secrets (they appear in the browser /authorize
# URL). redirect_uri MUST exactly match the one registered in the Alfa app.
ALFA_CLIENT_ID=your-client-id
ALFA_REDIRECT_URI=https://bank-import.bx-shef.by/oauth-alfabank-by/

# SECRET — server-side only, never in the repo or in chat/logs.
ALFA_CLIENT_SECRET=

# --- Frontend deploy (landing SSG image) ----------------------------------
# Domain the landing/in-portal image is served from (docker-compose.prod.yml:
# VIRTUAL_HOST / LETSENCRYPT_HOST for the nginx-proxy + acme-companion).
DOMAIN=bank-import.bx-shef.by
# ACME contact email for the TLS cert (acme-companion). Per-vhost override of
# the proxy's global DEFAULT_EMAIL.
LETSENCRYPT_EMAIL=shevchik.mail@gmail.com
# Author shown in the landing footer (build args → runtimeConfig.public.author*).
# Optional — defaults are baked into nuxt.config.ts.
NUXT_PUBLIC_AUTHOR_NAME=bx-shef
NUXT_PUBLIC_AUTHOR_URL=https://bx-shef.by
# Public URL the app is served from — used by the Bitrix24 install handler for
# absolute placement URLs (needed once placement.bind lands). Build-time only.
NUXT_PUBLIC_SITE_URL=https://bank-import.bx-shef.by

# --- Backend (B24 webhook endpoint + portal token store) ------------------
# Read by the `backend` service (docker-compose). The B24 event handler URL
# (ONAPPINSTALL/ONAPPUNINSTALL) points at /api/b24/events of this service.
# A startup check (server/plugins/envCheck.ts) validates these at boot and logs
# `[env] …` for anything wrong (bad key length, a CHANGE_ME token, missing DB).
#
# 32-byte key encrypting portal refresh_token at rest (AES-256-GCM).
# Generate: openssl rand -hex 32. Required — no default (a known key = no encryption).
B24_TOKEN_ENC_KEY=
# application_token is delivered INSIDE the ONAPPINSTALL event, PER PORTAL, and
# stored write-once; later events are verified against that stored value. So for a
# multi-tenant app LEAVE THIS EMPTY — the first install bootstraps trust (a single
# value can't match every portal's token). It is used here only as the shared guard
# token for server-only diagnostics (/api/queues, /api/b24/app-option-check); set it
# to some strong random value if you want those enabled. See docs/B24_EVENTS.md.
B24_APPLICATION_TOKEN=
# App OAuth credentials (client_id / client_secret of the registered B24 app).
# Needed to refresh the portal access token for server-side REST (app.option, etc.).
# Optional for a test right after install (the frame token is fresh ~1h); required
# for long-lived operation once tokens age out.
# client_id is not secret; B24_CLIENT_SECRET IS a real secret — server-side only,
# never in the repo or in chat/logs (same handling as ALFA_CLIENT_SECRET above).
B24_CLIENT_ID=
B24_CLIENT_SECRET=
# SSRF allow-list for the outbound REST host (#149). The frame routes take the portal
# `domain` from a caller-supplied header, so callRest only ever POSTs to a cloud
# `*.bitrix24.<tld>` portal by default. If you run a SELF-HOSTED (on-prem) Bitrix24 on a
# custom domain, list its host(s) here (comma/space separated) — else its REST is refused.
# Cloud portals need nothing here. Example: B24_SELFHOSTED_HOSTS=b24.acme.tld,crm.corp.local
# HOST ONLY: exact hostname match (no wildcard `*.acme.tld`), no port — REST always uses
# https on :443. A scheme/path in an entry is stripped to its bare host.
B24_SELFHOSTED_HOSTS=
# Postgres password for the `db` service. Required by docker-compose.prod.yml
# (used for both the db and the backend's DATABASE_URL). Use a URL-safe value with
# no @ : / ? # — the DSN embeds it unencoded. `openssl rand -hex 24` is ideal.
POSTGRES_PASSWORD=
# Postgres DSN. Prod compose builds it from POSTGRES_PASSWORD automatically; set
# this only when running the backend outside compose.
# DATABASE_URL=postgres://app:app@db:5432/app
# Redis DSN for the BullMQ pipeline (events → fetch → parse → crm-sync). Compose
# sets it to the internal `redis` service; override only when running outside compose.
# REDIS_URL=redis://redis:6379
# Cron poll interval in minutes (default 5) for REAL polling (A10). On the cron instance,
# every CRON_INTERVAL_MIN the poller enqueues one fetch job per connected bank account
# (A6 registry over the bank_tokens store) for a rolling window [today−CRON_LOOKBACK_DAYS,
# today]. INERT until accounts are connected (A7) — an empty registry enqueues nothing.
# DEFAULT OFF (opt-in) — the A8 rate limiter isn't built yet and this drives the live Alfa
# API (100 req/min), so enable it (CRON_REAL_POLL=1) only alongside A8, so connecting the
# first account (A7) can't silently start unthrottled polling. CRON_LOOKBACK_DAYS (default 1)
# re-covers days where operations post late. Prior is skipped until A5b.
# CRON_REAL_POLL=0
# CRON_LOOKBACK_DAYS=1
# Load demo: DEMO_LOAD_N>0 makes the demo enqueue that many synthetic
# fetch jobs every DEMO_TICK_SEC seconds (default 5), and DEMO_DELAY_MS (default 600)
# is an artificial per-job processing pause applied ONLY to demo accounts so the
# queues show a visible backlog on the /queues chart (0 = instant drain, flat line).
# Watch via /queues (operator session) or scripts/queue-stats.sh. Set DEMO_LOAD_N=0
# in prod once real polling lands. Keep the demo self-limiting (crm-sync won't grow):
#   DEMO_LOAD_N * 2 * DEMO_DELAY_MS <= DEMO_TICK_SEC * 1000  (defaults 3/600/5 ≈ 72%).
# CRON_INTERVAL_MIN=5
# DEMO_LOAD_N=0
# DEMO_TICK_SEC=5
# DEMO_DELAY_MS=600
# Proactive OAuth keep-alive (#175): once every N hours the cron instance refreshes only
# portals whose refresh_token is within ~3 days of its ~180-day expiry, so idle portals
# don't silently lose auth. Needs B24_CLIENT_ID/SECRET. Default 24h; clamped to [1h, 168h]
# (the near-expiry window is only ~3 days, so a longer cadence would miss portals; B24 also
# warns that frequent refreshing risks an app auto-block, so daily is the sweet spot).
# TOKEN_KEEPALIVE_HOURS=24

# Wall-clock retention sweep for the statement-PII queues (#245, docs/PRIVACY.md): the cron
# instance eagerly runs queue.clean on file-parse/crm-sync every N minutes so financial PII
# (file bytes / parsed operations) can't linger past its age on an idle portal — BullMQ's age
# eviction is LAZY (fires only on the next terminal job). On by default (privacy posture);
# opt out with STATEMENT_SWEEP=0. Interval default 30 min, clamped to [1, 10080].
# STATEMENT_SWEEP=1
# STATEMENT_SWEEP_INTERVAL_MIN=30

# OpenTelemetry (#78, docs/OBSERVABILITY.md). DEFAULT OFF: with OTEL_EXPORTER_OTLP_ENDPOINT
# unset the backend behaves exactly as before (the --import bootstrap no-ops). Set the endpoint
# to your OTLP collector to turn on traces+metrics. Financial PII never becomes span attributes
# (allowlist + redaction + hashed portal id) — see docs/PRIVACY.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# TELEMETRY_ENABLED=1                       # set 0 to force-off even with an endpoint
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer CHANGE_ME
# OTEL_SERVICE_NAME=client-bank-alfa-by-backend
# OTEL_SERVICE_VERSION=                     # defaults to NUXT_PUBLIC_COMMIT_SHA

# Queue role (one image, three roles — see docs/QUEUES.md «Масштабирование»). Defaults
# below = single container (does everything). In docker-compose.prod.yml the roles are
# split: backend runs QUEUE_WORKERS=0 (API + cron), the `worker` service runs the jobs.
# QUEUE_WORKERS=1        # process jobs in this instance (0 on the HTTP/primary container)
# QUEUE_CRON=1           # run the cron scheduler here — must be 1 on EXACTLY ONE instance
# QUEUE_CONCURRENCY=1    # per-worker parallelism (fetch/parse/crm-sync); raise WITH batching
# RUN_MIGRATION=1        # run schema migration on boot (0 on worker replicas)
# Bank-fetch rate limit (A8): a GLOBAL BullMQ limiter on the fetch queue — shared across ALL
# worker replicas via Redis, so live Alfa calls never exceed QUEUE_FETCH_RATE_MAX per
# QUEUE_FETCH_RATE_DURATION_MS across the whole fleet. Default 100/60000ms = Alfa's per-OAuth-client
# cap (our app has one Alfa client_id → one global cap is correct). A 0/garbage value falls back to
# the default (the cap can't be disabled by a typo). Lower it if Alfa tightens the limit.
# QUEUE_FETCH_RATE_MAX=100
# QUEUE_FETCH_RATE_DURATION_MS=60000
# Explicit saturation signal for the cap above (A8 follow-up): after each real poll the cron logs
# an A8-saturation WARNING when the bank-fetch backlog (waiting+delayed) crosses this threshold —
# so hitting the cap is greppable, not a mystery backlog on the chart. Default 200; 0/garbage → default
# (can't be silenced by a typo). NOTE: measures the whole fetch queue, so keep DEMO_LOAD_N=0 in a
# real-poll deployment (demo jobs would inflate the backlog and false-trip the warning).
# QUEUE_FETCH_SATURATION_THRESHOLD=200
# Manual «Опросить сейчас» test trigger (#54): POST /api/poll-now enqueues an on-demand bank poll
# of the caller-portal's connected accounts (admin-gated). OFF by default — frequency is regulated
# APP-SIDE, not by a portal user/admin: set MANUAL_POLL_ENABLED=1 to opt portals in. A per-portal
# cooldown (MANUAL_POLL_COOLDOWN_SEC, default 60) + the global A8 limiter keep it under the bank rate.
# MANUAL_POLL_ENABLED=1
# MANUAL_POLL_COOLDOWN_SEC=60
# Distribution smart-process contour (#109 §9): provision (/api/distribution/provision), read
# (/api/distribution/ledger) and recompute (/api/distribution/recompute) the ledger smart processes.
# Admin-gated frame token, single-flight. ON BY DEFAULT at this dev stage — it CREATES smart processes
# on the portal. Opt OUT explicitly with DISTRIBUTION_PROVISION_ENABLED=0.
# DISTRIBUTION_PROVISION_ENABLED=0
# crm-sync REST transport (#191) is the @bitrix24/b24jssdk SDK (built-in per-portal
# rate-limiter) — no flag; the former callRest fallback was retired.
#
# crm-sync writes each operation as a CONFIGURABLE activity (crm.activity.configurable.add),
# which carries an ORIGINATOR_ID/ORIGIN_ID marker — dedup lives in B24 (crm.activity.list
# search), no local store, no flag. It's OAuth/app-context only (can't be webhook-tested);
# smoke it on an installed portal with `pnpm activity:test --company <id> --apply`.

# --- Bank online-fetch OAuth (stage 5: online statement polling) ----------------
# Per-bank OAuth client creds + token endpoint the backend uses to REFRESH a portal's
# connected bank access token (server/utils/ensureBankToken.ts). All THREE per bank are
# required — a partial set silently disables that bank's online fetch (envCheck warns at
# boot). Leave blank until online fetch is wired for a portal. NB: these are BACKEND names
# (distinct from the dev recon scripts' ALFA_CLIENT_ID/ALFA_BASE_URL in .env.alfabankby).
# Alfa authenticates in the body; Prior via Authorization: Basic (client_secret_basic).
# ALFA_OAUTH_CLIENT_ID=
# ALFA_OAUTH_CLIENT_SECRET=
# ALFA_OAUTH_TOKEN_URL=https://developerhub.alfabank.by:8273/token
# Connect flow (A7b): the redirect_uri registered in the Alfa app (must match EXACTLY) and the
# requested scope. The authorize host is derived from ALFA_OAUTH_TOKEN_URL (strip `/token`), so no
# separate authorize-base var. Without ALFA_OAUTH_REDIRECT_URI the connect endpoint returns 400.
# ALFA_OAUTH_REDIRECT_URI=https://bank-import.bx-shef.by/api/bank/callback
# ALFA_OAUTH_SCOPE=accounts
# PRIOR_OAUTH_CLIENT_ID=
# PRIOR_OAUTH_CLIENT_SECRET=
# PRIOR_OAUTH_TOKEN_URL=https://api.priorbank.by:9544/token
#
# Statement API base + path the transport GETs the statement window from
# (server/utils/bankFetch.ts `bankApiConfig`). Distinct from the *_TOKEN_URL above:
# TOKEN_URL refreshes the OAuth token; API_BASE is the resource host. Unset ⇒ that
# bank's online fetch is OFF (fetchBankStatement throws rather than silently returning
# []). Alfa path defaults to the partner prefix `/partner/1.2.0` (override via
# ALFA_OAUTH_API_PREFIX). Prior's async create+poll path is A5b (not wired yet).
# ALFA_OAUTH_API_BASE=https://developerhub.alfabank.by:8273
# ALFA_OAUTH_API_PREFIX=/partner/1.2.0
# PRIOR_OAUTH_API_BASE=https://api.priorbank.by:9544

# --- Operator login (employee/ops area: /queues, later the import pages) --------
# Public /login form outside Bitrix24. WITHOUT a password the login endpoint returns
# 503 and the gated area stays OPEN (auth disabled) — set a password to enable it.
PUBLIC_PAGE_BASIC_AUTH_USER=operator
# Shared operator password. Server-side only, never in the repo/logs. Required to
# ENABLE login. Generate: openssl rand -hex 16.
PUBLIC_PAGE_BASIC_AUTH_PASS=
# HMAC secret signing the session cookie. In dev/test, if empty it is derived from
# the password (so a set password alone works). In PRODUCTION it is REQUIRED and is
# NOT derived from the password (a leaked cookie would otherwise enable an offline
# attack on the password): unset in prod ⇒ the operator zone is LOCKED (fail-closed),
# and the backend logs a startup ERROR. openssl rand -hex 32.
SESSION_SECRET=
# Session lifetime in hours (default 12).
# SESSION_TTL_HOURS=12

# --- Feedback channel (docs/FEEDBACK.md, channel «сотрудник») -------------------
# Employee 👍/👎 on the import result → a GitHub issue in a PRIVATE receiving repo.
# FAIL-CLOSED: the channel is OFF (widget hidden, POST /api/feedback → 503) unless
# BOTH are set. Never point the repo at the public code repo — employee comments may
# carry client data (account, sums, counterparties). The repo MUST be private.
# GitHub token with `issues:write` on the receiving repo (fine-grained PAT).
GITHUB_FEEDBACK_TOKEN=
# owner/repo of the PRIVATE receiving repo (e.g. bx-shef/client-bank-alfa-by-feedback).
GITHUB_FEEDBACK_REPO=
