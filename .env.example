# Alfa-Bank Belarus OAuth / API config (read by the backend/transport layer).
# Copy to `.env` and fill in. NEVER commit real secrets — `.env` is gitignored.
#
# OAuth base URL: sandbox `https://developerhub.alfabank.by:8273`,
# production `https://ibapi2.alfabank.by:8273`.
ALFA_BASE_URL=https://developerhub.alfabank.by:8273
# production:
# ALFA_BASE_URL=https://ibapi2.alfabank.by:8273

# client_id / redirect_uri are not secrets (they appear in the browser /authorize
# URL). redirect_uri MUST exactly match the one registered in the Alfa app.
ALFA_CLIENT_ID=your-client-id
ALFA_REDIRECT_URI=https://bank-import.bx-shef.by/oauth-alfabank-by/

# SECRET — server-side only, never in the repo or in chat/logs.
ALFA_CLIENT_SECRET=
