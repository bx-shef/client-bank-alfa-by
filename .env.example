# Alfa-Bank Belarus OAuth / API config (read by the backend/transport layer).
# Copy to `.env` and fill in. NEVER commit real secrets — `.env` is gitignored.
#
# OAuth base URL: sandbox `https://developerhub.alfabank.by:8273`,
# production `https://ibapi2.alfabank.by:8273`.
ALFA_BASE_URL=https://developerhub.alfabank.by:8273
# production:
# ALFA_BASE_URL=https://ibapi2.alfabank.by:8273

# client_id / redirect_uri are not secrets (they appear in the browser /authorize
# URL). redirect_uri MUST exactly match the one registered in the Alfa app.
ALFA_CLIENT_ID=your-client-id
ALFA_REDIRECT_URI=https://bank-import.bx-shef.by/oauth-alfabank-by/

# SECRET — server-side only, never in the repo or in chat/logs.
ALFA_CLIENT_SECRET=

# --- Frontend deploy (landing SSG image) ----------------------------------
# Domain the landing/in-portal image is served from (docker-compose.prod.yml:
# VIRTUAL_HOST / LETSENCRYPT_HOST for the nginx-proxy + acme-companion).
DOMAIN=bank-import.bx-shef.by
# ACME contact email for the TLS cert (acme-companion). Per-vhost override of
# the proxy's global DEFAULT_EMAIL.
LETSENCRYPT_EMAIL=shevchik.mail@gmail.com
# Author shown in the landing footer (build args → runtimeConfig.public.author*).
# Optional — defaults are baked into nuxt.config.ts.
NUXT_PUBLIC_AUTHOR_NAME=bx-shef
NUXT_PUBLIC_AUTHOR_URL=https://bx-shef.by
# Public URL the app is served from — used by the Bitrix24 install handler for
# absolute placement URLs (needed once placement.bind lands). Build-time only.
NUXT_PUBLIC_SITE_URL=https://bank-import.bx-shef.by

# --- Backend (B24 webhook endpoint + portal token store) ------------------
# Read by the `backend` service (docker-compose). The B24 event handler URL
# (ONAPPINSTALL/ONAPPUNINSTALL) points at /api/b24/events of this service.
# A startup check (server/plugins/envCheck.ts) validates these at boot and logs
# `[env] …` for anything wrong (bad key length, a CHANGE_ME token, missing DB).
#
# 32-byte key encrypting portal refresh_token at rest (AES-256-GCM).
# Generate: openssl rand -hex 32. Required — no default (a known key = no encryption).
B24_TOKEN_ENC_KEY=
# application_token is delivered INSIDE the ONAPPINSTALL event, PER PORTAL, and
# stored write-once; later events are verified against that stored value. So for a
# multi-tenant app LEAVE THIS EMPTY — the first install bootstraps trust (a single
# value can't match every portal's token). It is used here only as the shared guard
# token for server-only diagnostics (/api/queues, /api/b24/app-option-check); set it
# to some strong random value if you want those enabled. See docs/B24_EVENTS.md.
B24_APPLICATION_TOKEN=
# App OAuth credentials (client_id / client_secret of the registered B24 app).
# Needed to refresh the portal access token for server-side REST (app.option, etc.).
# Optional for a test right after install (the frame token is fresh ~1h); required
# for long-lived operation once tokens age out.
# client_id is not secret; B24_CLIENT_SECRET IS a real secret — server-side only,
# never in the repo or in chat/logs (same handling as ALFA_CLIENT_SECRET above).
B24_CLIENT_ID=
B24_CLIENT_SECRET=
# Postgres password for the `db` service. Required by docker-compose.prod.yml
# (used for both the db and the backend's DATABASE_URL). Use a URL-safe value with
# no @ : / ? # — the DSN embeds it unencoded. `openssl rand -hex 24` is ideal.
POSTGRES_PASSWORD=
# Postgres DSN. Prod compose builds it from POSTGRES_PASSWORD automatically; set
# this only when running the backend outside compose.
# DATABASE_URL=postgres://app:app@db:5432/app
# Redis DSN for the BullMQ pipeline (events → fetch → parse → crm-sync). Compose
# sets it to the internal `redis` service; override only when running outside compose.
# REDIS_URL=redis://redis:6379
# Cron poll interval in minutes (default 5) for REAL polling (empty until accounts
# are stored). Load demo: DEMO_LOAD_N>0 makes the demo enqueue that many synthetic
# fetch jobs every DEMO_TICK_SEC seconds (default 5), and DEMO_DELAY_MS (default 600)
# is an artificial per-job processing pause applied ONLY to demo accounts so the
# queues show a visible backlog on the /queues chart (0 = instant drain, flat line).
# Watch via /queues (operator session) or scripts/queue-stats.sh. Set DEMO_LOAD_N=0
# in prod once real polling lands. Keep the demo self-limiting (crm-sync won't grow):
#   DEMO_LOAD_N * 2 * DEMO_DELAY_MS <= DEMO_TICK_SEC * 1000  (defaults 3/600/5 ≈ 72%).
# CRON_INTERVAL_MIN=5
# DEMO_LOAD_N=0
# DEMO_TICK_SEC=5
# DEMO_DELAY_MS=600

# --- Operator login (employee/ops area: /queues, later the import pages) --------
# Public /login form outside Bitrix24. WITHOUT a password the login endpoint returns
# 503 and the gated area stays OPEN (auth disabled) — set a password to enable it.
PUBLIC_PAGE_BASIC_AUTH_USER=operator
# Shared operator password. Server-side only, never in the repo/logs. Required to
# ENABLE login. Generate: openssl rand -hex 16.
PUBLIC_PAGE_BASIC_AUTH_PASS=
# HMAC secret signing the session cookie. If empty, it is derived from the password
# (so a set password alone works) — but in PRODUCTION set an independent value:
# with a derived secret, a leaked cookie enables an offline attack on the actual
# password. The backend logs a startup warning if this is unset in production.
# openssl rand -hex 32.
SESSION_SECRET=
# Session lifetime in hours (default 12).
# SESSION_TTL_HOURS=12
