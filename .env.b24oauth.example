# OAuth creds of a live test portal for `pnpm sdk:crm:test` (#191 SDK-transport gate).
# NOT committed (real file is git-ignored). Fill from `scripts/extract-oauth-from-docker.sh`
# (run on the server where the backend Docker holds an OAuth-installed portal — it prints this
# exact block). Then: `pnpm sdk:crm:test` (reads, envelope) or `pnpm sdk:crm:test --force-refresh`
# (also exercises refresh + persist; ROTATES the refresh token → reinstall/re-extract after).

B24_OAUTH_DOMAIN=your-portal.bitrix24.by
B24_OAUTH_MEMBER_ID=abcdef0123456789
B24_OAUTH_ACCESS_TOKEN=
B24_OAUTH_REFRESH_TOKEN=
B24_OAUTH_EXPIRES_IN=3600
B24_CLIENT_ID=local.xxxxxxxxxxxxxxxx.xxxxxxxx
B24_CLIENT_SECRET=
