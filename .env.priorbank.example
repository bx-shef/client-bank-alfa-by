# Priorbank Open Banking (СПР) sandbox config for `pnpm prior:test`.
# Copy to `.env.priorbank` and fill in. NEVER commit real secrets (gitignored).
# Sandbox only — plain TLS, no СКЗИ. Prod (apibel.priorbank.by:9345) needs the
# BY-crypto TLS gateway (see docs/PRIOR_API.md and issue #41).

# OAuth base. Sandbox:
PRIOR_BASE=https://api.priorbank.by:9344

# Technological app (Магазин API → подписка на Open-banking-DCR → тестовые ключи).
# Used only for `--dcr` / `--oidc` (registering the business app).
PRIOR_TECH_CLIENT_ID=
PRIOR_TECH_CLIENT_SECRET=

# Business app (created by `--dcr` via POST /register). Day-to-day flow uses these.
PRIOR_CLIENT_ID=
PRIOR_CLIENT_SECRET=

# redirect_uri — MUST match the one registered for the business app.
PRIOR_REDIRECT_URI=https://bank-import.bx-shef.by/oauth-priorbank-by/

# RSA private key (PEM) that signs the authorize `request` JWT. Its public JWK
# must be registered in the app's `jwks` (kid must match PRIOR_KID).
# Generate a keypair + jwks with:  pnpm prior:test --gen-key
PRIOR_PRIVATE_KEY=prior_private_key.pem
PRIOR_KID=prior-key-1

# Optional: query one account directly (skip GET /accounts listing).
# PRIOR_ACCOUNT_ID=
