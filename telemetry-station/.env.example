# Shared telemetry station secrets. Copy to `.env` (git-ignored) and fill in.
# The station is deployed once; every app that pushes telemetry uses OTEL_COLLECTOR_AUTH_TOKEN
# as its `Authorization: Bearer` header (OTEL_EXPORTER_OTLP_HEADERS on the app side).

# Bearer token every OTLP push must present. Generate: openssl rand -hex 24
OTEL_COLLECTOR_AUTH_TOKEN=CHANGE_ME

# ClickHouse password (storage). Generate: openssl rand -hex 24
CLICKHOUSE_PASSWORD=CHANGE_ME

# Grafana admin password (UI login: admin / this). Generate: openssl rand -hex 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
