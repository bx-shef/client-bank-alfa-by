{
  "name": "client-bank-alfa-by",
  "type": "module",
  "private": true,
  "description": "Приложение для получения выписки из клиент-банка Альфа-Банк Беларусь (Nuxt SSG)",
  "license": "MIT",
  "author": "ИП Шевчик И. С.",
  "homepage": "https://github.com/bx-shef/client-bank-alfa-by#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bx-shef/client-bank-alfa-by.git"
  },
  "bugs": {
    "url": "https://github.com/bx-shef/client-bank-alfa-by/issues"
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit && vue-tsc -p .nuxt/tsconfig.server.json --noEmit",
    "typecheck:server": "vue-tsc -p .nuxt/tsconfig.server.json --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "screenshot": "node scripts/screenshot.mjs",
    "og": "node scripts/make-og.mjs",
    "oauth:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/alfa-oauth-test.mjs",
    "prior:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/prior-oauth-test.mjs",
    "parse:statement": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/parse-statement.ts",
    "fuzz:allocation": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/fuzz-allocation.ts",
    "seed:b24": "node scripts/seed-test-b24.mjs",
    "verify:109": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/verify-109-live.ts",
    "verify:chat": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/verify-chat-live.ts",
    "mutate:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/mutate-payment-live.ts",
    "sdk:test": "node scripts/b24-sdk-test.mjs",
    "sdk:crm:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/sdk-crm-test.ts",
    "sdk:oauth": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/sdk-oauth-test.ts",
    "activity:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/configurable-activity-test.ts",
    "trigger:test": "node --experimental-strip-types --disable-warning=ExperimentalWarning --import ./scripts/lib/alias-loader.mjs scripts/trigger-register-test.ts",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@bitrix24/b24icons-vue": "^2.0.7",
    "@bitrix24/b24jssdk": "^2.0.0",
    "@bitrix24/b24jssdk-nuxt": "^2.0.0",
    "@bitrix24/b24ui-nuxt": "^2.9.0",
    "@fontsource/roboto-mono": "^5.2.9",
    "@fontsource/rubik": "^5.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.62.2",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.205.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@opentelemetry/sdk-trace-base": "^2.1.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "bullmq": "^5.80.2",
    "echarts": "^6.1.0",
    "nuxt": "^4.4.7",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.11.10",
    "@types/qrcode": "^1.5.6",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.7.0",
    "happy-dom": "^20.10.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  }
}
